{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Scatter Plot: price vs mpg",
  "width": 600,
  "height": 400,
  "mark": {
    "type": "point",
    "filled": true,
    "opacity": 0.7
  },
  "encoding": {
    "x": {
      "field": "price",
      "type": "quantitative",
      "scale": {}
    },
    "y": {
      "field": "mpg",
      "type": "quantitative",
      "scale": {}
    },
    "color": {
      "field": "transmission",
      "type": "nominal",
      "scale": {}
    },
    "size": {
      "field": "engineSize",
      "type": "quantitative"
    },
    "tooltip": [
      {
        "field": "price",
        "type": "quantitative"
      },
      {
        "field": "mpg",
        "type": "quantitative"
      },
      {
        "field": "transmission",
        "type": "nominal"
      },
      {
        "field": "engineSize",
        "type": "quantitative"
      }
    ]
  },
  "transform": [],
  "params": []
}
