{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Heatmap: charges by children and smoker",
  "width": 600,
  "height": 400,
  "mark": "rect",
  "encoding": {
    "x": {
      "field": "children",
      "type": "nominal",
      "scale": {}
    },
    "y": {
      "field": "smoker",
      "type": "nominal",
      "scale": {}
    },
    "color": {
      "aggregate": "mean",
      "field": "charges",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      }
    },
    "tooltip": [
      {
        "field": "children",
        "type": "nominal"
      },
      {
        "field": "smoker",
        "type": "nominal"
      },
      {
        "field": "charges",
        "type": "quantitative"
      }
    ]
  },
  "transform": [],
  "params": []
}
